<!DOCTYPE html>
<html lang="en">
<head>
    <title>Mental Health Resources</title>
    <style>
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 10px; border: 1px solid #ddd; text-align: left; }
        th { background-color: #f4f4f4; }
    </style>
</head>
<body>
<nav>
    <a href="/index">Home</a>

    <a href="/article/add">Add New Article</a>
</nav>

<h2>Preset Knowledge Base</h2>

<table>
    <thead>
    <tr>
        <th>Article Title</th>
        <th>Author</th>
        <th>Content</th>
        <th>Linked Resource</th>
        <th>Additional Information</th>
    </tr>
    </thead>
    <tbody>
    {{#articles}}
        <tr>
            <td><strong>{{title}}</strong></td>
            <td>{{author}}</td>
            <td>{{{content}}}</td>

            {{#relatedResource}}
                <td>{{name}} ({{type}})</td>
                <td>
                    {{#phoneNumber}}Tel: {{phoneNumber}}{{/phoneNumber}}
                    {{#website}}<a href="http://{{website}}">{{website}}</a>{{/website}}
                </td>
            {{/relatedResource}}

            {{^relatedResource}}
                <td colspan="2" style="color: gray;">General Information</td>
            {{/relatedResource}}
        </tr>
    {{/articles}}
    </tbody>
</table>
</body>
</html>