<!DOCTYPE html>
<html lang="en">
<head>
    <title>Mental Health Resources</title>
    <style>
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 10px; border: 1px solid #ddd; text-align: left; }
        th { background-color: #f4f4f4; }
    </style>
</head>
<body>
<nav>
    <a href="/index">Home</a>

    <a href="/article/add">Add New Article</a>
</nav>

<h2>Preset Knowledge Base</h2>

<table>
    <thead>
    <tr>
        <th>Article Title</th>
        <th>Author</th>
        <th>Contents</th>
    </tr>
    </thead>
    <tbody>
    {{#articles}}
        <tr>
            <td><strong>{{title}}</strong></td>
            <td>{{author}}</td>
            <td>{{{content}}}</td>
        </tr>
    {{/articles}}
    </tbody>
</table>
</body>
</html>